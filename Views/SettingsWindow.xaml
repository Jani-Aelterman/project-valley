<winuiex:WindowEx
    x:Class="NextValleyDock.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    mc:Ignorable="d"
    Width="950" Height="660"
    MinWidth="800" MinHeight="500"
    Title="Next Valley — Instellingen">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="False"
                    IsTitleBarAutoPaddingEnabled="True"
                    SelectionChanged="NavView_SelectionChanged"
                    IsBackButtonVisible="Collapsed">

        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="AlgemeenItem" Content="Algemeen" Tag="Algemeen">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE115;"/></NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItemSeparator/>

            <NavigationViewItem Content="Paneel" Tag="Paneel">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE73F;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Dock" Tag="Dock">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Dynamische Dock" Tag="DynamischeDock">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE89A;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20,40,40">
            <Grid>

                <!-- ALGEMEEN PAGE -->
                <StackPanel x:Name="AlgemeenPage" Spacing="4" Visibility="Visible">
                    <TextBlock Text="Algemeen" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock Text="Systeem" FontSize="13" FontWeight="SemiBold" Margin="2,8,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <FontIcon Glyph="&#xE7E8;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Opstarten bij Windows" FontSize="14"/>
                                <TextBlock Text="Start Next Valley automatisch bij het aanmelden"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="StartAtBootToggle" Grid.Column="2"
                                          Margin="8,0,0,0" VerticalAlignment="Center"
                                          OnContent="" OffContent=""
                                          Toggled="ToggleStartAtBoot_Toggled"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Over" FontSize="13" FontWeight="SemiBold" Margin="2,20,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#1E6FBE">
                                <FontIcon Glyph="&#xE946;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Next Valley" FontSize="14"/>
                                <TextBlock Text="Versie 0.1.0 — Vroege preview"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- PANEEL PAGE -->
                <StackPanel x:Name="PaneelPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Paneel" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock Text="Uiterlijk" FontSize="13" FontWeight="SemiBold" Margin="2,8,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#6B4FA0">
                                <FontIcon Glyph="&#xE771;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Transparante achtergrond" FontSize="14"/>
                                <TextBlock Text="Gebruik een doorzichtige achtergrond"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                          OnContent="" OffContent="" IsOn="True"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#6B4FA0">
                                <FontIcon Glyph="&#xE8A1;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Hoogte paneel (pixels)" FontSize="14"/>
                                <TextBlock Text="Standaard: 64px"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <NumberBox Grid.Column="2" Minimum="32" Maximum="128" Value="64"
                                       Width="100" Margin="8,0,0,0" VerticalAlignment="Center"
                                       SpinButtonPlacementMode="Compact"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="8"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="0,40" Margin="0,12">
                        <StackPanel HorizontalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xF142;" FontSize="28"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Meer paneelinstelling komen binnenkort"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DOCK PAGE -->
                <StackPanel x:Name="DockPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Dock" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <Border CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="0,60" Margin="0,8">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xF142;" FontSize="36"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dock instellingen" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Beschikbaar wanneer de Dock functie is toegevoegd"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DYNAMISCHE DOCK PAGE -->
                <StackPanel x:Name="DynamischeDockPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Dynamische Dock" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <Border CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="0,60" Margin="0,8">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xF142;" FontSize="36"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dynamische Dock" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Combineert Dock en Paneel met ingebouwde system tray"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                            <TextBlock Text="Beschikbaar in een toekomstige versie"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </NavigationView>

</winuiex:WindowEx>

<winuiex:WindowEx
    x:Class="NextValleyDock.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    mc:Ignorable="d"
    Width="950" Height="660"
    MinWidth="800" MinHeight="500"
    Title="Next Valley — Settings">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="False"
                    IsTitleBarAutoPaddingEnabled="True"
                    SelectionChanged="NavView_SelectionChanged"
                    IsBackButtonVisible="Collapsed">

        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="GeneralItem" Content="General" Tag="General">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE115;"/></NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItemSeparator/>

            <NavigationViewItem Content="Panel" Tag="Panel">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE73F;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Dock" Tag="Dock">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Dynamic Dock" Tag="DynamicDock">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE89A;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,20,40,40">
            <Grid>

                <!-- ALGEMEEN PAGE -->
                <StackPanel x:Name="GeneralPage" Spacing="4" Visibility="Visible">
                    <TextBlock Text="General" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock Text="System" FontSize="13" FontWeight="SemiBold" Margin="2,8,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <FontIcon Glyph="&#xE7E8;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" FontSize="14"/>
                                <TextBlock Text="Start Project Valley automatically on login"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="StartAtBootToggle" Grid.Column="2"
                                          Margin="8,0,0,0" VerticalAlignment="Center"
                                          OnContent="" OffContent=""
                                          Toggled="ToggleStartAtBoot_Toggled"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="About" FontSize="13" FontWeight="SemiBold" Margin="2,20,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#1E6FBE">
                                <FontIcon Glyph="&#xE946;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Project Valley" FontSize="14"/>
                                <TextBlock Text="Version 0.1.0 — Early preview"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- PANEEL PAGE -->
                <StackPanel x:Name="PanelPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Panel" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock Text="Look" FontSize="13" FontWeight="SemiBold" Margin="2,8,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#6B4FA0">
                                <FontIcon Glyph="&#xE73F;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Show top panel" FontSize="14"/>
                                <TextBlock Text="Display the status bar at the top of the screen"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ShowTopPanelToggle" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                          OnContent="" OffContent="" Toggled="ToggleShowTopPanel_Toggled"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#0078D7">
                                <FontIcon Glyph="&#xE83F;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Show battery percentage" FontSize="14"/>
                                <TextBlock Text="Display the battery percentage next to the icon"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ShowBatteryPercentageToggle" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                          OnContent="" OffContent="" Toggled="ToggleBatteryPercentage_Toggled"/>
                        </Grid>
                    </Border>
                    
                    <TextBlock Text="Weather" FontSize="13" FontWeight="SemiBold" Margin="2,8,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#FFB900">
                                <FontIcon Glyph="&#xE81D;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Custom coordinates" FontSize="14"/>
                                <TextBlock Text="Location for weather (leave empty for auto IP detection)"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBox x:Name="LatTextBox" Grid.Column="2" PlaceholderText="Latitude" TextChanged="Location_TextChanged" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBox x:Name="LonTextBox" Grid.Column="3" PlaceholderText="Longitude" TextChanged="Location_TextChanged" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,2">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#6B4FA0">
                                <FontIcon Glyph="&#xE8A1;" Foreground="White" FontSize="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Height panel (pixels)" FontSize="14"/>
                                <TextBlock Text="Standard: 64px"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <NumberBox Grid.Column="2" Minimum="32" Maximum="128" Value="64"
                                       Width="100" Margin="8,0,0,0" VerticalAlignment="Center"
                                       SpinButtonPlacementMode="Compact"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="8"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="0,40" Margin="0,12">
                        <StackPanel HorizontalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xF142;" FontSize="28"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="More panelsettigns coming soon"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DOCK PAGE -->
                <StackPanel x:Name="DockPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Dock" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <Border CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#0078D7">
                                    <FontIcon Glyph="&#xE8F1;" Foreground="White" FontSize="16"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Show dock" FontSize="14"/>
                                    <TextBlock Text="Display the application dock at the bottom of the screen"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="ShowDockToggle" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                              OnContent="" OffContent="" Toggled="ToggleShowDock_Toggled"/>
                            </Grid>

                            <MenuFlyoutSeparator/>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#4A4A4A">
                                    <FontIcon Glyph="&#xECCD;" Foreground="White" FontSize="16"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Hide Windows taskbar" FontSize="14"/>
                                    <TextBlock Text="Automatically hide the system taskbar when the dock is active"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="HideTaskbarToggle" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                              OnContent="" OffContent="" Toggled="ToggleHideTaskbar_Toggled"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DYNAMISCHE DOCK PAGE -->
                <StackPanel x:Name="DynamicDockPage" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Dynamic Dock" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <Border CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="0,60" Margin="0,8">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xF142;" FontSize="36"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dynamic Dock" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Advanced features like auto-expanding app groups and system tray"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                            <TextBlock Text="Coming soon in a future version"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </NavigationView>

</winuiex:WindowEx>

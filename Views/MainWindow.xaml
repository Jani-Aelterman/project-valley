<winuiex:WindowEx
    x:Class="NextValleyDock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    xmlns:tb="using:H.NotifyIcon"
    mc:Ignorable="d"
    Title="Next Valley Panel">

    <!-- Mica backdrop commented out - using Win32 DWM transparency instead -->
    <!--<Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>-->

    <Grid Background="Transparent" 
      VerticalAlignment="Stretch" 
      HorizontalAlignment="Stretch"
      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
      BorderThickness="0,0,0,1">

    <!-- Achtergrond paneel met Mica/Acrylic-feel & afgeronde hoeken -->
        <!--<Border CornerRadius="22" 
                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" 
                Padding="24,4"
                Margin="12,2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>-->

            <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 1. Weer Widget (Left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTipService.ToolTip="Weer">
                    <FontIcon Glyph="&#xE706;" FontSize="20" Foreground="Orange"/>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="18°C" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="Zonnig" FontSize="11" />
                    </StackPanel>
                </StackPanel>

                <!-- 2. Zoekbalk / Command Palette (Center) -->
                <Border Grid.Column="1" CornerRadius="18" Background="{ThemeResource ControlFillColorDefaultBrush}" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <!-- Zoek Icoon -->
                        <FontIcon Glyph="&#xE721;" FontSize="16" Margin="12,0,8,0" Foreground="Gray" VerticalAlignment="Center"/>

                        <!-- Zoek Tekst -->
                        <TextBox PlaceholderText="Typ hier om te zoeken..." 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 VerticalAlignment="Center" 
                                 PlaceholderForeground="Gray"
                                 Width="180"
                                 FontSize="14"
                                 Margin="0,0,8,0"/>

                        <!-- Geneste Pill 1: App Icoon -->
                        <Border CornerRadius="14" Background="{ThemeResource SystemAccentColor}" Margin="0,4,4,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,6,0">
                                <FontIcon Glyph="&#xE7FC;" FontSize="14" Foreground="White"/>

                                <!-- Geneste Pill 2: App Naam -->
                                <Border CornerRadius="10" Background="#33000000" Margin="6,0,0,0" Padding="8,2">
                                    <TextBlock Text="App Name" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 3. Status Area (Right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Control Center -->
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <Button Background="Transparent" BorderThickness="0" Padding="6">
                            <FontIcon Glyph="&#xE701;" FontSize="16"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="6">
                            <FontIcon Glyph="&#xE767;" FontSize="16"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="6">
                            <FontIcon Glyph="&#xE83F;" FontSize="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Divider -->
                    <!--<Rectangle Width="1" Height="20" Fill="Gray" Opacity="0.3" VerticalAlignment="Center"/>-->

                    <!-- Datum / Tijd -->
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8" ToolTipService.ToolTip="Kalender en Meldingen">
                        <TextBlock x:Name="DateTextBlock" Text="vr 12 oktober" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="TimeTextBlock" Text="10:41" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        <!--</Border>-->
    </Grid>
</winuiex:WindowEx>
<winuiex:WindowEx
    x:Class="NextValleyDock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    xmlns:tb="using:H.NotifyIcon"
    mc:Ignorable="d"
    Title="Next Valley Panel">

    <!-- Mica backdrop commented out - using Win32 DWM transparency instead -->
    <!--<Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>-->

    <Grid Background="Transparent" 
      VerticalAlignment="Stretch" 
      HorizontalAlignment="Stretch"
      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
      BorderThickness="0,0,0,1">

    <!-- Background panel with Mica/Acrylic-feel & ronded corners -->
        <!--<Border CornerRadius="22" 
                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" 
                Padding="24,4"
                Margin="12,2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>-->

            <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Padding="15, 0, 15, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 1. Weather Widget (Left) -->
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="8,4" CornerRadius="6" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTipService.ToolTip="Weather" Click="OpenWidgets">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE706;" FontSize="20" Foreground="Orange"/>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="18°C" FontWeight="Bold" FontSize="13" />
                            <TextBlock Text="Sunny" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 2. Searchbar / Command Palette (Center) -->
                <Border Grid.Column="1" CornerRadius="14" Background="{ThemeResource ControlFillColorDefaultBrush}" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <!-- Search Icon -->
                        <FontIcon Glyph="&#xE721;" FontSize="14" Margin="10,0,6,0" Foreground="Gray" VerticalAlignment="Center"/>

                        <!-- Search text -->
                        <TextBox PlaceholderText="Type here to search..." 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 VerticalAlignment="Center" 
                                 PlaceholderForeground="Gray"
                                 Width="180"
                                 FontSize="12"
                                 Margin="0,0,6,0"/>

                        <!-- Active App Pill -->
                        <Grid Margin="0,2,2,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- App Icon Pill (ZIndex 1 makes it on top) -->
                            <Border Grid.Column="0" x:Name="ActiveAppIconContainer" CornerRadius="12" Background="{ThemeResource SystemAccentColor}" Padding="6,2" Canvas.ZIndex="1">
                                <Image x:Name="ActiveAppIcon" Width="16" Height="16" VerticalAlignment="Center"/>
                            </Border>

                            <!-- App Name Pill (Negative margin left makes it slide under icon pill) -->
                            <Border Grid.Column="1" Padding="14,2,10,2" Margin="-12,0,0,0" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush}" VerticalAlignment="Stretch">
                                <TextBlock x:Name="ActiveAppName" Text="App Name" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,0"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Status Area (Right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Control Center -->
                    <Button Background="Transparent" BorderThickness="0" Padding="12,6" CornerRadius="6" VerticalAlignment="Center" ToolTipService.ToolTip="Quick settings" Click="OpenActionCenter">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon x:Name="NetworkIcon" Glyph="&#xE701;" FontSize="14"/>
                            <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon x:Name="BatteryIcon" Glyph="&#xE83F;" FontSize="14"/>
                                <TextBlock x:Name="BatteryPercentageText" Text="100%" FontSize="11" VerticalAlignment="Center" Visibility="Visible"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Date / Time -->
                    <Button Background="Transparent" BorderThickness="0" Padding="8,6" CornerRadius="6" VerticalAlignment="Center" ToolTipService.ToolTip="Calendar and notifications" Click="OpenCalendar">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="DateTextBlock" Text="date" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock x:Name="TimeTextBlock" Text="time" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        <!--</Border>-->
    </Grid>
</winuiex:WindowEx>

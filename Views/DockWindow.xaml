<winuiex:WindowEx
    x:Class="NextValleyDock.Views.DockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    xmlns:helpers="using:NextValleyDock.Helpers"
    mc:Ignorable="d"
    Title="Next Valley Dock">

    <Grid Background="Transparent">
        <Border x:Name="PillRoot"
                CornerRadius="0" 
                Background="Transparent" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0" 
                Padding="0"
                Height="64"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <!-- Launcher Logo -->
                <Button x:Name="LauncherButton" 
                        Click="LauncherButton_Click"
                        Width="48" Height="48" 
                        Padding="0" Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0"
                        x:Uid="StartButton"
                        CornerRadius="12">
                    <Button.ContextFlyout>
                        <MenuFlyout Opened="MenuFlyout_Opened" Closed="MenuFlyout_Closed">
                            <MenuFlyoutItem x:Uid="MenuInstalledApps" Click="PowerMenu_Click" Tag="ms-settings:appsfeatures"/>
                            <MenuFlyoutItem x:Uid="MenuMobilityCenter" Click="PowerMenu_Click" Tag="mblctr"/>
                            <MenuFlyoutItem x:Uid="MenuPowerOptions" Click="PowerMenu_Click" Tag="ms-settings:powersleep"/>
                            <MenuFlyoutItem x:Uid="MenuEventViewer" Click="PowerMenu_Click" Tag="eventvwr"/>
                            <MenuFlyoutItem x:Uid="MenuSystem" Click="PowerMenu_Click" Tag="ms-settings:about"/>
                            <MenuFlyoutItem x:Uid="MenuDeviceManager" Click="PowerMenu_Click" Tag="devmgmt.msc"/>
                            <MenuFlyoutItem x:Uid="MenuNetworkConnections" Click="PowerMenu_Click" Tag="ms-settings:network"/>
                            <MenuFlyoutItem x:Uid="MenuDiskManagement" Click="PowerMenu_Click" Tag="diskmgmt.msc"/>
                            <MenuFlyoutItem x:Uid="MenuComputerManagement" Click="PowerMenu_Click" Tag="compmgmt.msc"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:Uid="MenuTerminal" Click="PowerMenu_Click" Tag="wt"/>
                            <MenuFlyoutItem x:Uid="MenuTerminalAdmin" Click="PowerMenu_Click" Tag="wt-admin"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:Uid="MenuTaskManager" Click="PowerMenu_Click" Tag="taskmgr"/>
                            <MenuFlyoutItem x:Uid="MenuSettings" Click="PowerMenu_Click" Tag="ms-settings:home"/>
                            <MenuFlyoutItem x:Uid="MenuFileExplorer" Click="PowerMenu_Click" Tag="explorer"/>
                            <MenuFlyoutItem x:Uid="MenuSearch" Click="PowerMenu_Click" Tag="ms-search:"/>
                            <MenuFlyoutItem x:Uid="MenuRun" Click="PowerMenu_Click" Tag="run"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutSubItem x:Uid="MenuShutDownOrSignOut">
                                <MenuFlyoutItem x:Uid="MenuSignOut" Click="PowerMenu_Click" Tag="logoff"/>
                                <MenuFlyoutItem x:Uid="MenuSleep" Click="PowerMenu_Click" Tag="sleep"/>
                                <MenuFlyoutItem x:Uid="MenuShutDown" Click="PowerMenu_Click" Tag="shutdown"/>
                                <MenuFlyoutItem x:Uid="MenuRestart" Click="PowerMenu_Click" Tag="restart"/>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutItem x:Uid="MenuDesktop" Click="PowerMenu_Click" Tag="desktop"/>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                    <BitmapIcon UriSource="ms-appx:///Assets/Windows11Logo.png" 
                                ShowAsMonochrome="True" 
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                Width="28" Height="28" 
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Separator -->
                <Rectangle Width="1" Height="24" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5" Margin="4,0"/>

                <ItemsControl ItemsSource="{x:Bind RunningApps, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="helpers:WindowInfo">
                            <Button Click="AppIcon_Click"
                                    Padding="0" Margin="0"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}">
                                <Button.ContextFlyout>
                                    <MenuFlyout Opened="MenuFlyout_Opened" Closed="MenuFlyout_Closed">
                                        <MenuFlyoutItem x:Uid="MenuPinToTaskbar" 
                                                        Click="PinItem_Click" 
                                                        Visibility="{x:Bind helpers:Converters.IsNotPinnedToVisibility(IsPinned), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE718;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="MenuUnpinFromTaskbar" 
                                                        Click="UnpinItem_Click" 
                                                        Visibility="{x:Bind helpers:Converters.IsPinnedToVisibility(IsPinned), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE77A;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                                <Grid Width="56" Height="56">
                                    <Image Source="{x:Bind Icon, Mode=OneWay}" 
                                           Stretch="Uniform" 
                                           Width="38" Height="38" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"
                                           Opacity="{x:Bind helpers:Converters.IsRunningToOpacity(IsRunning), Mode=OneWay}"/>
                                    
                                    <Ellipse Width="6" Height="2" 
                                             Fill="{ThemeResource SystemAccentColorLight2}" 
                                             VerticalAlignment="Bottom" 
                                             HorizontalAlignment="Center"
                                             Margin="0,0,0,6"
                                             Visibility="{x:Bind helpers:Converters.IsRunningToVisibility(IsRunning), Mode=OneWay}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</winuiex:WindowEx>

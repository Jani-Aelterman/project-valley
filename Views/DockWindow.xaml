<winuiex:WindowEx
    x:Class="NextValleyDock.Views.DockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    xmlns:helpers="using:NextValleyDock.Helpers"
    mc:Ignorable="d"
    Title="Next Valley Dock">

    <Grid Background="Transparent">
        <Border x:Name="PillRoot"
                CornerRadius="0" 
                Background="Transparent" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0" 
                Padding="0"
                Height="64"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <!-- Launcher Logo -->
                <Button x:Name="LauncherButton" 
                        Click="LauncherButton_Click"
                        Width="48" Height="48" 
                        Padding="0" Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Start"
                        CornerRadius="12">
                    <Button.ContextFlyout>
                        <MenuFlyout Opened="MenuFlyout_Opened" Closed="MenuFlyout_Closed">
                            <MenuFlyoutItem Text="Installed apps" Click="PowerMenu_Click" Tag="ms-settings:appsfeatures"/>
                            <MenuFlyoutItem Text="Mobility Center" Click="PowerMenu_Click" Tag="mblctr"/>
                            <MenuFlyoutItem Text="Power Options" Click="PowerMenu_Click" Tag="ms-settings:powersleep"/>
                            <MenuFlyoutItem Text="Event Viewer" Click="PowerMenu_Click" Tag="eventvwr"/>
                            <MenuFlyoutItem Text="System" Click="PowerMenu_Click" Tag="ms-settings:about"/>
                            <MenuFlyoutItem Text="Device Manager" Click="PowerMenu_Click" Tag="devmgmt.msc"/>
                            <MenuFlyoutItem Text="Network Connections" Click="PowerMenu_Click" Tag="ms-settings:network"/>
                            <MenuFlyoutItem Text="Disk Management" Click="PowerMenu_Click" Tag="diskmgmt.msc"/>
                            <MenuFlyoutItem Text="Computer Management" Click="PowerMenu_Click" Tag="compmgmt.msc"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Terminal" Click="PowerMenu_Click" Tag="wt"/>
                            <MenuFlyoutItem Text="Terminal (Admin)" Click="PowerMenu_Click" Tag="wt-admin"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Task Manager" Click="PowerMenu_Click" Tag="taskmgr"/>
                            <MenuFlyoutItem Text="Settings" Click="PowerMenu_Click" Tag="ms-settings:home"/>
                            <MenuFlyoutItem Text="File Explorer" Click="PowerMenu_Click" Tag="explorer"/>
                            <MenuFlyoutItem Text="Search" Click="PowerMenu_Click" Tag="ms-search:"/>
                            <MenuFlyoutItem Text="Run" Click="PowerMenu_Click" Tag="run"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutSubItem Text="Shut down or sign out">
                                <MenuFlyoutItem Text="Sign out" Click="PowerMenu_Click" Tag="logoff"/>
                                <MenuFlyoutItem Text="Sleep" Click="PowerMenu_Click" Tag="sleep"/>
                                <MenuFlyoutItem Text="Shut down" Click="PowerMenu_Click" Tag="shutdown"/>
                                <MenuFlyoutItem Text="Restart" Click="PowerMenu_Click" Tag="restart"/>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutItem Text="Desktop" Click="PowerMenu_Click" Tag="desktop"/>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                    <Border CornerRadius="0" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush ImageSource="ms-appx:///Assets/Windows11Logo.png" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Button>

                <!-- Separator -->
                <Rectangle Width="1" Height="24" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5" Margin="4,0"/>

                <ItemsControl ItemsSource="{x:Bind RunningApps, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="helpers:WindowInfo">
                            <Button Click="AppIcon_Click"
                                    Padding="0" Margin="0"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}">
                                <Button.ContextFlyout>
                                    <MenuFlyout Opened="MenuFlyout_Opened" Closed="MenuFlyout_Closed">
                                        <MenuFlyoutItem Text="Pin to Taskbar" 
                                                        Click="PinItem_Click" 
                                                        Visibility="{x:Bind helpers:Converters.IsNotPinnedToVisibility(IsPinned), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE718;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Unpin from Taskbar" 
                                                        Click="UnpinItem_Click" 
                                                        Visibility="{x:Bind helpers:Converters.IsPinnedToVisibility(IsPinned), Mode=OneWay}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE77A;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                                <Grid Width="56" Height="56">
                                    <Image Source="{x:Bind Icon, Mode=OneWay}" 
                                           Stretch="Uniform" 
                                           Width="38" Height="38" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"
                                           Opacity="{x:Bind helpers:Converters.IsRunningToOpacity(IsRunning), Mode=OneWay}"/>
                                    
                                    <Ellipse Width="6" Height="2" 
                                             Fill="{ThemeResource SystemAccentColorLight2}" 
                                             VerticalAlignment="Bottom" 
                                             HorizontalAlignment="Center"
                                             Margin="0,0,0,6"
                                             Visibility="{x:Bind helpers:Converters.IsRunningToVisibility(IsRunning), Mode=OneWay}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</winuiex:WindowEx>
